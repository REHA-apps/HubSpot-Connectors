{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "HubSpot CRM Connector",
    "description": "Search HubSpot contacts, companies, and deals from Slack.",
    "long_description": "HubSpot CRM Connector allows you to seamlessly find and share HubSpot contacts, companies, and deals directly within Slack. Boost your team's productivity by accessing CRM data without switching apps. This integration provides powerful search capabilities, AI-driven insights, and easy collaboration for your sales and support teams, making it easier than ever to manage customer relationships efficiently.",
    "background_color": "#0052CC"
  },
  "settings": {
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": true,
    "event_subscriptions": {
      "request_url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/events",
      "bot_events": [
        "message.channels",
        "message.im",
        "message.groups",
        "message.mpim",
        "app_mention",
        "link_shared",
        "app_uninstalled"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/interactions"
    }
  },
  "features": {
    "bot_user": {
      "display_name": "REHA Bot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/hs",
        "url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/commands",
        "description": "Smart HubSpot search",
        "usage_hint": "[query]",
        "should_escape": false
      },
      {
        "command": "/hs-contacts",
        "url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/commands",
        "description": "Search HubSpot contacts",
        "usage_hint": "email, name, or query",
        "should_escape": false
      },
      {
        "command": "/hs-deals",
        "url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/commands",
        "description": "Search HubSpot deals",
        "usage_hint": "deal name or keyword",
        "should_escape": false
      },
      {
        "command": "/hs-companies",
        "url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/commands",
        "description": "Search HubSpot companies",
        "usage_hint": "company name or domain",
        "should_escape": false
      },
      {
        "command": "/hs-leads",
        "url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/commands",
        "description": "Search HubSpot leads",
        "usage_hint": "lead name or email",
        "should_escape": false
      },
      {
        "command": "/hs-tickets",
        "url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/commands",
        "description": "Search HubSpot tickets",
        "usage_hint": "ticket subject or ID",
        "should_escape": false
      },
      {
        "command": "/hs-tasks",
        "url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/commands",
        "description": "Search HubSpot tasks",
        "usage_hint": "task name",
        "should_escape": false
      },
      {
        "command": "/hs-kb",
        "url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/commands",
        "description": "Search Knowledge Base",
        "usage_hint": "topic or question",
        "should_escape": false
      },
      {
        "command": "/hs-playbook",
        "url": "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/commands",
        "description": "Search Playbooks",
        "usage_hint": "playbook name",
        "should_escape": false
      }
    ],
    "shortcuts": [
      {
        "name": "Create HubSpot Record",
        "type": "global",
        "callback_id": "create_hubspot_record",
        "description": "Create a new Contact, Deal, Task, or Ticket"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "commands",
        "chat:write",
        "chat:write.public",
        "users:read",
        "users:read.email",
        "app_mentions:read",
        "im:history",
        "channels:history",
        "groups:history",
        "mpim:history",
        "links:read",
        "links:write",
        "channels:read",
        "groups:read"
      ]
    },
    "redirect_urls": [
      "https://derisible-jeremy-ambilaterally.ngrok-free.dev/api/slack/oauth/callback"
    ]
  }
}
